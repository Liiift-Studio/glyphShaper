{
	"name": "@liiift-studio/glyphforge",
	"version": "0.0.1",
	"description": "Interactive glyph path editor — click any character, reshape its bezier curves, and watch every instance on the page update instantly",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run test && npm run build"
	},
	"dependencies": {
		"opentype.js": "^1.3.4"
	},
	"peerDependencies": {
		"react": ">=17",
		"react-dom": ">=17"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/opentype.js": "^1.3.9",
		"@types/react": "^19.0.0",
		"@vitejs/plugin-react": "^4.0.0",
		"happy-dom": "^12.0.0",
		"next": "16.2.2",
		"react": "^19.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.0.0",
		"vite-plugin-dts": "^4.0.0",
		"vitest": "^3.0.0"
	},
	"keywords": [
		"typography",
		"glyph",
		"bezier",
		"font",
		"opentype",
		"path-editing",
		"font-face",
		"variable-font",
		"interactive",
		"TypeScript",
		"react",
		"npm"
	],
	"author": "Quinn Keaveney <quinn@liiift.studio>",
	"license": "MIT",
	"homepage": "https://glyphforge.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/Liiift-Studio/glyphForge.git"
	},
	"bugs": {
		"url": "https://github.com/Liiift-Studio/glyphForge/issues"
	},
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	}
}
